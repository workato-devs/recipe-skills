                "name": "Email",
                "optional": true,
                "sticky": true,
                "type": "string",
                "sfdc_createable": true,
                "sfdc_updateable": true
              },
              {
                "control_type": "text",
                "custom": false,
                "label": "Account ID",
                "name": "AccountId",
