                "optional": true,
                "type": "string",
                "sfdc_createable": true,
                "sfdc_updateable": true
              },
              {
                "control_type": "phone",
                "custom": false,
                "label": "Business Phone",
                "name": "Phone",
                "optional": true,
                "type": "string",
                "sfdc_createable": true,
                "sfdc_updateable": true
              }
