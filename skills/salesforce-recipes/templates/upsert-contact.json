                  {
                    "control_type": "checkbox",
                    "label": "Created",
                    "render_input": "boolean_conversion",
                    "parse_output": "boolean_conversion",
                    "name": "created",
                    "type": "boolean",
                    "toggle_hint": "Select from option list",
                    "toggle_field": {
                      "label": "Created",
                      "control_type": "text",
                      "toggle_hint": "Use custom value",
                      "name": "created",
                      "type": "boolean"
                    }
                  }
