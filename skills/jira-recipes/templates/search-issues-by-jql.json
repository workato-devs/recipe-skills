    "block": [
      {
        "number": 1,
        "keyword": "try",
        "input": {},
        "block": [
          {
            "number": 2,
            "keyword": "if",
            "as": "check_project_key",
            "input": {
              "type": "compound",
              "operand": "and",
              "conditions": [
                {
                  "operand": "present",
                  "lhs": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"workato_api_platform\",\"line\":\"api_trigger\",\"path\":[\"request\",\"project_key\"]}')}",
                  "uuid": "cond-project-key-001"
                }
              ]
            },
            "block": [
              {
                "number": 3,
                "provider": "jira",
                "name": "search_issues_by_JQL",
                "as": "jira_search",
                "keyword": "action",
                "input": {
                  "jql": "='project = \"' + _dp('{\"pill_type\":\"output\",\"provider\":\"workato_api_platform\",\"line\":\"api_trigger\",\"path\":[\"request\",\"project_key\"]}') + '\"' + (_dp('{\"pill_type\":\"output\",\"provider\":\"workato_api_platform\",\"line\":\"api_trigger\",\"path\":[\"request\",\"sprint_name\"]}').present? ? ' AND sprint = \"' + _dp('{\"pill_type\":\"output\",\"provider\":\"workato_api_platform\",\"line\":\"api_trigger\",\"path\":[\"request\",\"sprint_name\"]}') + '\"' : ' AND sprint in openSprints()')"
                },
                "extended_input_schema": [],
