{
  "name": "Search Jira issues by JQL",
  "description": "Search Jira issues via JQL query. Required: project_key (string). Optional: sprint_name (string, defaults to open sprints). Response (200): project_key, issues_json (JSON array), total_issues (count), error_message (null). (400: missing project_key) (500: Jira API error)",
  "version": 1,
  "private": true,
  "concurrency": 1,
  "code": {
    "number": 0,
    "provider": "workato_api_platform",
    "name": "receive_request",
    "as": "api_trigger",
    "keyword": "trigger",
    "input": {
      "request": {
        "content_type": "json",
        "schema": "[{\"name\":\"project_key\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Project Key\",\"optional\":false,\"hint\":\"Jira project key (e.g. ENG, MOB)\"},{\"name\":\"sprint_name\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Sprint Name\",\"optional\":true,\"hint\":\"Sprint name filter. If omitted, returns issues from open sprints.\"}]"
      },
      "response": {
        "content_type": "json",
        "responses": [
          {
            "name": "Success",
            "http_status_code": "200",
            "body_schema": "[{\"name\":\"project_key\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Project Key\"},{\"name\":\"issues_json\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Issues JSON\"},{\"name\":\"total_issues\",\"type\":\"number\",\"control_type\":\"number\",\"label\":\"Total Issues\"},{\"name\":\"error_message\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Error Message\"}]"
          },
          {
            "name": "Bad Request",
            "http_status_code": "400",
            "body_schema": "[{\"name\":\"project_key\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Project Key\"},{\"name\":\"issues_json\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Issues JSON\"},{\"name\":\"total_issues\",\"type\":\"number\",\"control_type\":\"number\",\"label\":\"Total Issues\"},{\"name\":\"error_message\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Error Message\"}]"
          },
          {
            "name": "Server Error",
            "http_status_code": "500",
            "body_schema": "[{\"name\":\"project_key\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Project Key\"},{\"name\":\"issues_json\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Issues JSON\"},{\"name\":\"total_issues\",\"type\":\"number\",\"control_type\":\"number\",\"label\":\"Total Issues\"},{\"name\":\"error_message\",\"type\":\"string\",\"control_type\":\"text\",\"label\":\"Error Message\"}]"
          }
        ]
      }
    },
