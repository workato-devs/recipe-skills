        "label": "Request",
        "name": "request",
        "type": "object",
        "properties": [
          {
            "control_type": "text",
            "label": "Project Key",
            "name": "project_key",
            "type": "string",
            "optional": false
          },
          {
            "control_type": "text",
            "label": "Sprint Name",
            "name": "sprint_name",
            "type": "string",
            "optional": true
          }
        ]
      }
